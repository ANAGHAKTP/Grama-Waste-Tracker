<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GramaWasteTracker" parent="Theme.Material3.Dark">
        <!-- Colors -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorTertiary">@color/accent_tertiary</item>
        <item name="colorError">@color/accent_error</item>
        
        <!-- Background -->
        <item name="colorBackground">@color/primary_dark_bg</item>
        <item name="colorSurface">@color/secondary_dark_bg</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Shape -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CustomMedium</item>
    </style>
    
    <style name="ShapeAppearance.CustomMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>
